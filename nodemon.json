{
  "watch": [
    "supabase/**/*.sql",
    "middleware.ts",
    "next.config.js"
  ],
  "ext": "sql,ts,js",
  "ignore": [
    "node_modules/**/*",
    ".next/**/*",
    "*.log"
  ],
  "env": {
    "NODE_ENV": "development"
  },
  "events": {
    "restart": "echo '\n🔄 Restarting due to file changes...\n'"
  },
  "delay": 1000
}