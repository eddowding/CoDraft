#!/usr/bin/env sh

# Pre-commit hook: Regenerate Supabase TypeScript types if migrations changed
# This ensures type definitions stay in sync with database schema

# Check if any migration files were staged
STAGED_MIGRATIONS=$(git diff --cached --name-only | grep -E "^supabase/migrations/.*\.sql$" || true)

if [ -n "$STAGED_MIGRATIONS" ]; then
  echo "📊 Database migrations detected, regenerating TypeScript types..."

  # Regenerate types into a TEMP file first, then validate before replacing.
  # NOTE: do NOT run `npm run supabase:gen-types` directly here — that script
  # redirects stdout straight onto lib/database.types.ts, so a failed run (e.g.
  # the `--linked` legacy endpoint returning an error) CLOBBERS the committed
  # types file with garbage. Writing to a temp file and only moving it over on
  # a sane result makes the regen non-destructive.
  TMP_TYPES="$(mktemp)"
  if npx supabase gen types typescript --linked > "$TMP_TYPES" 2>/dev/null \
     && head -n 1 "$TMP_TYPES" | grep -q "export type"; then
    mv "$TMP_TYPES" lib/database.types.ts
    git add lib/database.types.ts
    echo "✅ Types regenerated and staged"
  else
    rm -f "$TMP_TYPES"
    echo "⚠️ Type generation failed/unavailable - keeping existing lib/database.types.ts"
    echo "   Run 'npm run supabase:gen-types' manually if the schema changed"
  fi
fi

# Run TypeScript type check
# NOTE: do NOT pipe to 2>/dev/null here — it hides the real failure reason
# (e.g. "tsc: command not found" when node_modules is missing), making a
# blocked commit look mysterious. Let stderr through so errors are visible.
echo "🔍 Running type check..."
npm run typecheck

if [ $? -ne 0 ]; then
  echo "❌ TypeScript errors found. Please fix them before committing."
  exit 1
fi

echo "✅ Pre-commit checks passed"
