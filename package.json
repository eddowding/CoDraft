{
  "name": "docvote-supabase",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:watch": "nodemon --exec \"npm run dev\"",
    "dev:db": "nodemon --exec \"node scripts/apply-db-changes.js\"",
    "dev:full": "echo 'Run these in separate terminals: npm run dev (for Next.js) and npm run dev:db (for database watching)'",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "supabase:gen-types": "supabase gen types typescript --linked > lib/database.types.ts",
    "db:apply": "node scripts/apply-db-changes.js",
    "prepare": "husky"
  },
  "dependencies": {
    "@hookform/resolvers": "^3.3.4",
